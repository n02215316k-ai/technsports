DOMAIN=technsports.example.com
ACME_EMAIL=admin@technsports.example.com

POSTGRES_PASSWORD=replace-with-a-32-plus-character-random-secret
PASSWORD_PEPPER=replace-with-a-separate-32-plus-character-random-secret
ADMIN_API_KEY=replace-with-a-32-plus-character-random-secret-or-leave-empty

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true
SMTP_USER=smtp-user
SMTP_PASS=smtp-password
EMAIL_FROM=TechnSports <no-reply@technsports.example.com>

ALLOW_DEMO_SEED=false
